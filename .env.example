# Copy to .env and fill in. Never commit real secrets.

# --- Database / queue ---
DATABASE_URL=postgresql+asyncpg://ledger:ledger@localhost:5432/ledgercopilot
REDIS_URL=redis://localhost:6379/0

# --- Object storage (local: MinIO; prod: GCS/S3) ---
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=ledgercopilot-documents
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# --- AI Gateway (abstracts Anthropic/OpenAI; never call providers directly) ---
AI_GATEWAY_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_DEFAULT_MODEL=claude-opus-4-8
AI_FALLBACK_MODEL=claude-sonnet-4-6
# Cap on concurrent outbound model calls. 0 = unlimited (default). Set to a small
# positive value (e.g. 2) to stay under a provider's concurrent-connection limit
# during wide fan-outs like the eval (SC k=3 over many fixtures).
AI_MAX_CONCURRENCY=0

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
ACTIVE_PROMPT_ALIAS=dev
ACTIVE_POLICY_ALIAS=dev
# JWT signing key. The dev default works locally, but the API refuses to boot
# with ENVIRONMENT=production unless this is a strong, unique value (>=32 chars).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-secret-change-in-production-32chars
