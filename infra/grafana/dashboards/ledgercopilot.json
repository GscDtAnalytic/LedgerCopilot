{
  "title": "LedgerCopilot — LLMOps & Operations",
  "uid": "ledgercopilot-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["ledgercopilot", "llmops"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cases Received",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(ledger_cases_received_total)",
          "legendFormat": "received"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Auto-Approved",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(ledger_cases_decided_total{decision=\"auto_approved\"})",
          "legendFormat": "auto_approved"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Human Review",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(ledger_cases_decided_total{decision=\"in_human_review\"})",
          "legendFormat": "human_review"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Rejected",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(ledger_cases_decided_total{decision=\"rejected\"})",
          "legendFormat": "rejected"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Human Review Rate",
      "description": "% de casos que foram para revisão humana. Meta: < 30% (wiki: sli-slo-sla)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "unit": "percentunit"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(ledger_human_reviews_completed_total) / clamp_min(sum(ledger_cases_decided_total), 1)",
          "legendFormat": "review rate"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Injection Flags",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(ledger_injection_suspected_total)",
          "legendFormat": "injection flags"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Throughput — Cases Decided / min",
      "description": "Taxa de decisões por minuto. Contexto: meta > 1/min em produção.",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (decision) (rate(ledger_cases_decided_total[5m])) * 60",
          "legendFormat": "{{ decision }}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "LLM Cost / Hour (USD)",
      "description": "Custo acumulado por estágio por hora. cost/doc = custo total / total cases.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (stage) (rate(ledger_llm_cost_usd_total[5m])) * 3600",
          "legendFormat": "{{ stage }}"
        }
      ]
    },
    {
      "id": 20,
      "type": "bargauge",
      "title": "p95 LLM Latency by Stage (ms)",
      "description": "95º percentil de latência por estágio LLM. Wiki: barra > pizza. Meta: < 2000ms.",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 7 },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 2000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (stage, le) (rate(ledger_llm_latency_ms_bucket[5m])))",
          "legendFormat": "{{ stage }}"
        }
      ]
    },
    {
      "id": 21,
      "type": "bargauge",
      "title": "p95 Pipeline Stage Duration (ms)",
      "description": "95º percentil de duração por estágio do pipeline (inclui I/O + LLM).",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 7 },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (stage, le) (rate(ledger_pipeline_stage_duration_ms_bucket[5m])))",
          "legendFormat": "{{ stage }}"
        }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "LLM Tokens / min (input vs output)",
      "description": "Volume de tokens consumidos. Contexto: output tokens custam 5x mais que input.",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (token_type) (rate(ledger_llm_tokens_total[5m])) * 60",
          "legendFormat": "{{ token_type }}"
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Human Review Actions over Time",
      "description": "Aprovações / rejeições / edições por revisores humanos.",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (action) (rate(ledger_human_reviews_completed_total[5m])) * 60",
          "legendFormat": "{{ action }}"
        }
      ]
    }
  ]
}
